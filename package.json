{
  "name": "lib",
  "version": "1.0.0",
  "description": "standard library — served at https://johnhenry.github.io/lib/",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "prettier --write build.mjs scripts/verify-contract.mjs vitest.config.mjs config",
    "serve": "http-server . --port=3001 --cors -c-1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:pq": "bash ./script.sh run_popquiz",
    "start": "npm run serve",
    "start:over": "npm -s i && npm run -s build && npm run -s serve",
    "publish-ignore": "echo .publishignore > .gitignore",
    "build": "node build.mjs",
    "build:legacy": "sh build.sh",
    "verify": "node scripts/verify-contract.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnhenry/lib.git"
  },
  "keywords": [],
  "author": "John Henry",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/johnhenry/lib/issues"
  },
  "homepage": "https://johnhenry.github.io/lib/",
  "devDependencies": {
    "http-server": "^14.0.0",
    "marked": "^18.0.5",
    "prettier": "^3.6.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
